                        <workingDirectory>$PROJ_DIR$</workingDirectory>
                        <buildSequence>postLink</buildSequence>
                        <outputs>
                            <file>
                                <name>$BUILD_FILES_DIR$/.postbuild</name>
                            </file>
                        </outputs>
                    </buildAction>
                </buildActions>
            </data>
        </settings>
